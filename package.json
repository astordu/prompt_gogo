{
  "name": "prompt-gogo",
  "version": "1.0.0",
  "description": "A desktop app for processing selected text with AI using keyboard shortcuts",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test test/*.test.js",
    "dist": "electron-builder --mac dmg",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "ai",
    "text-processing",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.promptgogo.app",
    "productName": "Prompt Go",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "icon": "build/icon.png",
      "identity": null
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
